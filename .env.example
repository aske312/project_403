APP_NAME=Project_403
VERSION=0.0.2
BUILD_ID=dev
PROJECT_BRANCH=master
ENVIRONMENTS=dev

HOST=127.0.0.1
PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

VITE_API_URL=http://127.0.0.1:8000
VITE_AUTH_TOKEN_KEY=_token
VITE_INTERFACE_PREFERENCES_KEY=display
VITE_SESSION_EXPIRED_KEY=_expired
VITE_DEFAULT_THEME=dark
VITE_DEFAULT_LANGUAGE=RU

# External services are opt-in. Default baseline: frontend + backend + SQLite.
POSTGRESQL_ENABLED=False
REDIS_ENABLED=False
DOCKER_SERVICES_ENABLED=False

DATABASE_DRIVER=postgresql+asyncpg
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=messenger_db
DB_FALLBACK_ENABLED=True
DB_FALLBACK_URL=sqlite+aiosqlite:///./local.db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_RATE_LIMIT_PREFIX=project403:rate_limit
REDIS_RATE_LIMIT_KEY_TTL_SECONDS=120

JWT_SECRET=change_me_before_public_deploy
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=10
AUTH_REGISTER_RATE_LIMIT_ATTEMPTS=5

DEV_SUPERUSER_ENABLED=True
DEV_SUPERUSER_EMAIL=supervisor@project_403.local
DEV_SUPERUSER_HANDLE=supervisor
DEV_SUPERUSER_FIRST_NAME=Supervisor
DEV_SUPERUSER_LAST_NAME=
DEV_SUPERUSER_PASSWORD=Supervisor403

DEV_USER_ENABLED=True
DEV_USER_EMAIL=user@project_403.local
DEV_USER_HANDLE=user
DEV_USER_FIRST_NAME=User
DEV_USER_LAST_NAME=Dev
DEV_USER_PASSWORD=user12345

LOG_DIR=logs
STARTUP_LOG_TEMPLATE={version}.log
WORK_LOG_TEMPLATE={version}.log
DB_LOG_TEMPLATE={version}.log
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=5

RUNTIME_STATE_FILE=logs/runtime-state.json
RUNTIME_HEARTBEAT_SECONDS=5
ADMIN_COMMAND_FILE=logs/admin-command.json
ADMIN_COMMAND_TTL_SECONDS=60
FEATURE_FLAGS_FILE=config/feature-flags.yaml
