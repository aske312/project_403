{
  "project": {
    "defaultName": "Project_403",
    "defaultVersion": "0.0.2",
    "environment": "DEV",
    "debug": true,
    "autoCreateTables": true
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "frontendApiUrl": "http://localhost:8000",
    "corsOrigins": ["http://localhost:5173", "http://127.0.0.1:5173"]
  },
  "database": {
    "driver": "postgresql+asyncpg",
    "fallbackUrl": "sqlite+aiosqlite:///./local.db",
    "fallbackEnabled": true
  },
  "auth": {
    "jwtAlgorithm": "HS256",
    "accessTokenExpireMinutes": 60,
    "rateLimitWindowSeconds": 60,
    "loginRateLimitAttempts": 5,
    "registerRateLimitAttempts": 3
  },
  "runtime": {
    "stateFile": "logs/run-state.json",
    "heartbeatSeconds": 10,
    "adminCommandFile": "logs/admin-com-.json",
    "adminCommandTtlSeconds": 30
  },
  "logging": {
    "file": "logs/app-backend.log",
    "directory": "logs",
    "maxBytes": 1048576,
    "backupCount": 3
  }
}
